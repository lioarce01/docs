{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "chainforge",
  "colors": {
    "primary": "#6366F1",
    "light": "#818CF8",
    "dark": "#4F46E5"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/lioarce01/chainforge"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "/quickstart"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "guides/providers",
              "guides/tools",
              "guides/mcp",
              "guides/memory",
              "guides/vector-memory",
              "guides/rag",
              "guides/hitl",
              "guides/orchestration",
              "guides/structured-output",
              "guides/presets",
              "guides/testing"
            ]
          },
          {
            "group": "Production",
            "pages": [
              "guides/deployment",
              "guides/observability",
              "guides/benchmarks"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/options"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/lioarce01/chainforge",
          "icon": "github"
        },
        {
          "anchor": "pkg.go.dev",
          "href": "https://pkg.go.dev/github.com/lioarce01/chainforge",
          "icon": "box"
        }
      ]
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/lioarce01/chainforge"
    }
  }
}
